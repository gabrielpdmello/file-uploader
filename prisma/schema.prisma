generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String   
  expiresAt   DateTime
}

model User {
  id  Int @id @default(autoincrement())
  username String  @unique
  name  String?
  password  String
  folders Folder[]
}

model Folder {
  id String @id @default(uuid())
  name String
  parent String?
  user User @relation(fields: [ownerId], references: [id])
  ownerId Int
  files File[]
}

model File {
  id String @id @default(uuid())
  name String
  folder Folder @relation(fields: [folderId], references: [id])
  folderId String
}