generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String   
  expiresAt   DateTime
}

model User {
  id  Int @id @default(autoincrement())
  username String  @unique
  name  String?
  password  String
  folders Folder[]
}

model Folder {
  id String @id @default(uuid())
  name String
  parentId String?
  previousParentId String?
  parent   Folder?   @relation("parentChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[]  @relation("parentChildren")
  user User @relation(fields: [ownerId], references: [id])
  ownerId Int
  files File[]
  size Int @default(0)
  shared Boolean @default(false)
  share_folder_id String?
  share_date DateTime?
  last_update DateTime @default(now())
  accept_file Boolean @default(true)
  accept_folder Boolean @default(true)
  root String?
}

model File {
  id String @id
  name String
  folder Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  folderId String
  previousFolderId String?
  size Int?
  last_update DateTime @default(now())
  ownerId Int
  path String
}

model scheduled_jobs {
  id Int @id @default(autoincrement())
  job_type String
  item_id String @unique
  item_type String
  date DateTime
}

model job_logs {
  id Int @id @default(autoincrement())
  job_type String
  item_id String @unique
  item_type String
  date DateTime
}